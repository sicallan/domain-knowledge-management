      "Bash(sleep:*)",
      "Bash(seq:*)",
      "Bash(test:*)",
      "Bash(mkdir:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(which:*)",
      "Bash(command:*)",
