# DKM quickstart configuration. Copy to `.env` and adjust: `cp .env.example .env`.
# Tier A (the bundled demo) needs none of these — docker compose works out of the box.

# --- Tier B: process your own documents ------------------------------------------------
# Your Anthropic API key, used by `dkm process` for LLM extraction. Tier B only.
ANTHROPIC_API_KEY=

# --- Gateway data source ---------------------------------------------------------------
# Directory whose *.jsonl files the gateway serves. Empty/missing → the bundled Payments demo.
# (docker compose mounts ./data here by default.)
DKM_DATA_DIR=

# Explicit comma-separated JSONL paths (takes precedence over DKM_DATA_DIR).
DKM_JSONL=

# Gateway port (default 4000).
PORT=4000
