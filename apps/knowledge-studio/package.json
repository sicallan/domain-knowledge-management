{
  "name": "@dkm/knowledge-studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Knowledge Studio (UI-3.1): the React + Vite + TS application shell — nav, always-present search bar, slide-out context-panel slot, breadcrumb, notification centre, on a shadcn/Radix/Tailwind foundation. Presentation-only over the generated SDL types; data arrives via the @dkm/api-gateway GraphQL endpoint (live) or MSW (standalone, UI-D2).",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@dkm/api-gateway": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.2",
    "clsx": "^2.1.1",
    "cytoscape": "^3.30.0",
    "cytoscape-fcose": "^2.2.0",
    "graphql": "^16.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tailwind-merge": "^2.5.4",
    "urql": "^4.2.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "jsdom": "^25.0.1",
    "msw": "^2.6.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "vite": "^5.4.11",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.8",
    "vitest-axe": "^0.1.0"
  }
}
