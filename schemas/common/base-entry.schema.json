{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dkm.dev/schemas/common/base-entry.schema.json",
  "title": "BaseEntry",
  "description": "Common fields shared by every inventory entry. Open schema: additional fields are permitted (additive OCP evolution); consumers ignore unknown fields.",
  "type": "object",
  "allOf": [{ "$ref": "https://dkm.dev/schemas/common/temporal.schema.json" }],
  "required": ["id", "type", "version", "lifecycle_status", "evidencedBy"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "type": {
      "type": "string",
      "minLength": 1,
      "description": "Inventory type discriminator. Not a closed enum: new types register by adding a schema file (OCP)."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of this entry definition."
    },
    "lifecycle_status": {
      "type": "string",
      "enum": ["draft", "active", "deprecated", "retired"]
    },
    "evidencedBy": {
      "type": "array",
      "minItems": 1,
      "description": "Provenance links. Required: every asserted fact must be evidenced.",
      "items": { "$ref": "https://dkm.dev/schemas/common/provenance.schema.json#/$defs/evidence" }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "createdBy": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
