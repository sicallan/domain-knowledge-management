{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dkm.dev/schemas/inventory/L1/business-invariant.schema.json",
  "title": "BusinessInvariant",
  "description": "L1 — A condition that must always hold within its governing context.",
  "type": "object",
  "allOf": [{ "$ref": "https://dkm.dev/schemas/common/base-entry.schema.json" }],
  "required": ["statement", "severity", "scope"],
  "properties": {
    "type": { "const": "BusinessInvariant" },
    "statement": { "type": "string", "minLength": 1 },
    "governingContext": { "type": "string" },
    "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
    "scope": { "type": "string", "enum": ["global", "context-specific"] },
    "enforcementMechanism": { "type": "string" }
  }
}
