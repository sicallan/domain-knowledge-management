{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@dkm/schema": ["modules/schema/src/index.ts"],
      "@dkm/schema/*": ["modules/schema/src/*"],
      "@dkm/knowledge-graph": ["modules/knowledge-graph/src/index.ts"],
      "@dkm/knowledge-graph/*": ["modules/knowledge-graph/src/*"],
      "@dkm/loaders": ["modules/loaders/src/index.ts"],
      "@dkm/loaders/*": ["modules/loaders/src/*"],
      "@dkm/query": ["modules/query-interface/src/index.ts"],
      "@dkm/query/*": ["modules/query-interface/src/*"],
      "@dkm/view-projection": ["modules/view-projection/src/index.ts"],
      "@dkm/view-projection/*": ["modules/view-projection/src/*"],
      "@dkm/quality": ["modules/quality-verification/src/index.ts"],
      "@dkm/quality/*": ["modules/quality-verification/src/*"],
      "@dkm/source-connectors": ["modules/source-connectors/src/index.ts"],
      "@dkm/source-connectors/*": ["modules/source-connectors/src/*"],
      "@dkm/api-gateway": ["apps/api-gateway/src/index.ts"],
      "@dkm/api-gateway/*": ["apps/api-gateway/src/*"]
    }
  },
  "include": [
    "modules/*/src/**/*.ts",
    "modules/*/test/**/*.ts",
    "apps/api-gateway/src/**/*.ts",
    "apps/api-gateway/test/**/*.ts",
    "apps/processor/src/**/*.ts",
    "apps/processor/test/**/*.ts",
    "demo/src/**/*.ts",
    "*.config.ts"
  ]
}
